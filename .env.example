# Email — SMTP Hostinger
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contact@larmor-baden.com
SMTP_PASS=your_password_here

# Printful
PRINTFUL_CLIENT_ID=your_printful_client_id
PRINTFUL_SECRET_KEY=your_printful_secret_key
PRINTFUL_API_TOKEN=your_printful_private_token
NEXT_PUBLIC_SOUVENIRS_URL=https://souvenirs.larmor-baden.com

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Marées — WorldTides (clé gratuite sur https://www.worldtides.info/developer)
WORLDTIDES_API_KEY=your_worldtides_api_key

# Google AdSense (optionnel)
# NEXT_PUBLIC_ADSENSE_CLIENT = identifiant complet "ca-pub-XXXXXXXXXXXXXXXX" (charge le script)
# ADSENSE_PUB_ID = partie numérique "XXXXXXXXXXXXXXXX" (génère /ads.txt)
NEXT_PUBLIC_ADSENSE_CLIENT=
ADSENSE_PUB_ID=

# Affiliation (optionnel) — les encarts ne s'affichent que si l'ID est renseigné
# GetYourGuide (activités) : votre partner_id
NEXT_PUBLIC_GYG_PARTNER_ID=
# Booking.com (hébergement) : votre identifiant d'affilié "aid"
NEXT_PUBLIC_BOOKING_AID=
